{
  "name": "azure-devops-release-notes-mcp",
  "version": "1.0.0",
  "description": "Claude Code MCP plugin for generating Azure DevOps release notes from sprint work items",
  "main": "dist/index.js",
  "bin": {
    "ado-release-notes": "dist/index.js"
  },
  "files": [
    "dist/",
    "release-note-template.md",
    ".env.example",
    "CLAUDE.md",
    "CHANGELOG.md",
    "setup.sh"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "azure-devops",
    "release-notes",
    "devops",
    "wiki",
    "sprint"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Chamalasela/azure-devops-release-notes-mcp"
  },
  "scripts": {
    "build": "node --max-old-space-size=4096 node_modules/typescript/bin/tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "node --max-old-space-size=4096 node_modules/typescript/bin/tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "handlebars": "^4.7.8",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/handlebars": "^4.1.0",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
