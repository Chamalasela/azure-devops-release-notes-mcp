# ─── Required ────────────────────────────────────────────────────────────────

# Personal Access Token — create at dev.azure.com → User Settings → PATs
# Required scopes: Work Items (Read), Wiki (Read & Write), Queries (Read & Write)
AZURE_DEVOPS_PAT=your_personal_access_token_here

# Organization name — the {org} part of dev.azure.com/{org}
AZURE_DEVOPS_ORG=your-organization

# Project name as it appears in Azure DevOps
AZURE_DEVOPS_PROJECT=YourProject

# Wiki identifier — visible in the Wiki URL: /_wiki/wikis/{wiki-id}
AZURE_DEVOPS_WIKI_ID=YourProject.wiki

# ─── Optional (sensible defaults provided) ───────────────────────────────────

# Comma-separated work item types to include in release notes
# Default: User Story,Bug,Feature
AZURE_DEVOPS_WORK_ITEM_TYPES=User Story,Bug,Feature

# Iteration path prefix — the part of the path before the sprint name
# Example: if full path is "MyProject\Team Alpha\Sprint 42", prefix is "MyProject\Team Alpha"
# Default: same as AZURE_DEVOPS_PROJECT
AZURE_DEVOPS_ITERATION_PATH_PREFIX=YourProject

# Sprint name format — {{number}} is replaced with the sprint number you provide
# Default: Sprint {{number}}
AZURE_DEVOPS_SPRINT_NAME_FORMAT=Sprint {{number}}

# Azure DevOps Queries folder where the shared query will be saved
# Default: Shared Queries/Release Notes
AZURE_DEVOPS_SHARED_QUERY_PATH=Shared Queries/Release Notes

# Wiki folder path where release note pages will be created
# Default: /Release Notes
AZURE_DEVOPS_WIKI_PATH_PREFIX=/Release Notes

# Path to your Markdown release note template
# Default: ./release-note-template.md
RELEASE_NOTE_TEMPLATE_PATH=./release-note-template.md
